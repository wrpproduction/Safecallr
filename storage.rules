rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "xdcam10@gmail.com" ||
        request.auth.token.email == "ulrich.vidal@gmail.com" ||
        request.auth.token.email == "contact@wrpproduction.com" ||
        request.auth.token.email == "contact@remiprevel.com" ||
        firestore.exists(/databases/ai-studio-ffb666f4-67e6-42be-a2e6-2406f74f5b0d/documents/admins/$(request.auth.uid))
      );
    }

    match /profiles/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /documents/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /organizations/logos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
