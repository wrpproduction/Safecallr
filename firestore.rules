rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "xdcam10@gmail.com" ||
        request.auth.token.email == "ulrich.vidal@gmail.com" ||
        request.auth.token.email == "contact@wrpproduction.com" ||
        request.auth.token.email == "contact@remiprevel.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isPro() {
      return isAuthenticated() && exists(/databases/$(database)/documents/pros/$(request.auth.uid));
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidPersonalRequest(data) {
      return data.keys().hasAll(['fromUserId', 'fromUserName', 'fromUserPhone', 'toUserId', 'toUserName', 'toUserPhone', 'toUserEmail', 'status', 'createdAt']) &&
             data.status in ['pending', 'accepted', 'rejected'];
    }

    function isValidPersonalContact(data) {
      return data.keys().hasAll(['ownerId', 'name', 'phone', 'email', 'createdAt']);
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) ||
        isAdmin()
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // Pros collection
    match /pros/{proId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(proId);
      allow update: if isAdmin() || isOwner(proId);
      allow delete: if isAdmin();
    }

    // Companies collection
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isPro();
      allow delete: if isAdmin();
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Verification Requests
    match /verification_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.requesterId;
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Auth Requests
    match /authRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Pro Client Connections
    match /proClientConnections/{connectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Personal Contacts
    match /personalContacts/{contactId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.ownerId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    // User to User Connections
    match /userConnections/{connectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() || isAdmin();
    }

    // Personal Contact Requests
    match /personalContactRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Mail collection (Trigger Email extension)
    match /mail/{mailId} {
      allow create: if true; 
      allow read, write: if isAdmin();
    }

    // Verification Codes for Custom Email verification
    match /verification_codes/{tokenId} {
      allow create: if true;
      allow read, update: if true;
    }

    // Global stats metadata document for client-side count updates
    match /global/stats {
      allow read: if true;
      allow write: if true;
    }

    // Company Contact Requests
    match /companyContactRequests/{requestId} {
      allow create: if true; 
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Articles (Blog/Actualités) for SEO/GEO
    match /articles/{articleId} {
      allow read: if (resource == null) || (resource.data.published == true) || isAdmin();
      allow write: if isAdmin();
    }

    // Organizations
    match /organizations/{orgId} {
      allow get: if isOrgMember(orgId);
      allow list: if isAdmin();
      allow update: if isOrgMember(orgId);
      allow create, delete: if isAdmin();
      
      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId);
      }

      match /authRequests/{requestId} {
        allow read, write: if isOrgMember(orgId);
      }

      match /auditLog/{logId} {
        allow read: if isOrgMember(orgId);
        allow write: if isAdmin();
      }
    }
  }
}
